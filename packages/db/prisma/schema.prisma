generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  admin
  billing
  sales
  client
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  incomplete
}

enum TokenLedgerEntryType {
  plan_grant
  token_purchase
  hold
  release
  charge
  refund
  adjustment
}

enum WorkflowRunStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum WorkflowRunEventType {
  queued
  started
  progress
  succeeded
  failed
  canceled
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum AuditAction {
  user_invited
  role_changed
  plan_changed
  token_purchased
  workflow_created
  workflow_published
  workflow_run_requested
  workflow_run_finished
  support_ticket_created
  support_ticket_updated
}

model User {
  id             String                 @id @default(cuid())
  email          String                 @unique
  name           String?
  passwordHash   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  memberships    Membership[]
  workflowRuns   WorkflowRun[]          @relation("WorkflowRunRequestedBy")
  ticketsCreated SupportTicket[]        @relation("TicketCreatedBy")
  ticketComments SupportTicketComment[]
  auditLogs      AuditLog[]             @relation("AuditActor")
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  subscriptions  Subscription[]
  tokenWallet    TokenWallet?
  workflows      Workflow[]
  workflowRuns   WorkflowRun[]
  tickets        SupportTicket[]
  auditLogs      AuditLog[]
  tokenPurchases TokenPurchase[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           RoleKey
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Plan {
  id                String         @id @default(cuid())
  code              String         @unique
  name              String
  description       String?
  monthlyPriceCents Int
  includedTokens    Int
  monthlyRunQuota   Int
  isActive          Boolean        @default(true)
  stripePriceId     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subscriptions     Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  planId               String
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  stripeSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
}

model TokenWallet {
  id             String             @id @default(cuid())
  organizationId String             @unique
  balance        Int                @default(0)
  reserved       Int                @default(0)
  lifetimeSpent  Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledgerEntries  TokenLedgerEntry[]
}

model TokenLedgerEntry {
  id          String               @id @default(cuid())
  walletId    String
  type        TokenLedgerEntryType
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime             @default(now())
  wallet      TokenWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([referenceId])
}

model TokenPurchase {
  id               String       @id @default(cuid())
  organizationId   String
  tokens           Int
  priceCents       Int
  stripeCheckoutId String?      @unique
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Workflow {
  id              String            @id @default(cuid())
  organizationId  String
  key             String
  name            String
  description     String?
  activeVersionId String?
  tokenCost       Int               @default(1)
  isPublished     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions        WorkflowVersion[]
  runs            WorkflowRun[]

  @@unique([organizationId, key])
  @@index([organizationId, isPublished])
}

model WorkflowVersion {
  id                  String        @id @default(cuid())
  workflowId          String
  version             String
  parameterSchemaJson Json
  n8nWorkflowId       String
  isActive            Boolean       @default(false)
  createdAt           DateTime      @default(now())
  workflow            Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  runs                WorkflowRun[]

  @@unique([workflowId, version])
  @@index([workflowId, isActive])
}

model WorkflowRun {
  id                String             @id @default(cuid())
  workflowId        String
  workflowVersionId String
  organizationId    String
  requestedByUserId String
  idempotencyKey    String
  status            WorkflowRunStatus  @default(queued)
  parametersJson    Json
  resultJson        Json?
  errorMessage      String?
  tokenCostSnapshot Int
  n8nExecutionId    String?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workflow          Workflow           @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  workflowVersion   WorkflowVersion    @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  requestedBy       User               @relation("WorkflowRunRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  events            WorkflowRunEvent[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status])
  @@index([workflowId, createdAt])
}

model WorkflowRunEvent {
  id            String               @id @default(cuid())
  workflowRunId String
  type          WorkflowRunEventType
  message       String
  payloadJson   Json?
  createdAt     DateTime             @default(now())
  workflowRun   WorkflowRun          @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, createdAt])
}

model SupportTicket {
  id               String                 @id @default(cuid())
  organizationId   String
  createdByUserId  String
  assignedToUserId String?
  title            String
  description      String
  category         String
  status           TicketStatus           @default(open)
  priority         TicketPriority         @default(medium)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  resolvedAt       DateTime?
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("TicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  comments         SupportTicketComment[]

  @@index([organizationId, status])
}

model SupportTicketComment {
  id           String        @id @default(cuid())
  ticketId     String
  authorUserId String
  body         String
  internalOnly Boolean       @default(false)
  createdAt    DateTime      @default(now())
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         AuditAction
  resourceType   String
  resourceId     String
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
}
